rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isMember(roomId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.members;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    // User Profiles
    match /users/{userId} {
      // Anyone authenticated can read public keys to initiate chats
      allow read: if isAuthenticated();
      
      // Only the owner can create/update their profile
      allow create: if isOwner(userId) 
                    && hasRequiredFields(['username', 'email', 'publicKey'])
                    && hasOnlyAllowedFields(['username', 'email', 'publicKey'])
                    && request.resource.data.username is string
                    && request.resource.data.email is string
                    && request.resource.data.publicKey is string;
                    
      allow update: if isOwner(userId)
                    && hasOnlyAllowedFields(['username', 'email', 'publicKey'])
                    && request.resource.data.username is string
                    && request.resource.data.email is string
                    && request.resource.data.publicKey is string;
    }
    
    // Rooms
    match /rooms/{roomId} {
      // Only members can read the room details
      allow read: if isMember(roomId) || (request.auth != null && request.auth.uid in resource.data.members);
      
      // Anyone authenticated can create a room, but they must be the creator and a member
      allow create: if isAuthenticated()
                    && hasRequiredFields(['name', 'creatorId', 'isDirect', 'members'])
                    && hasOnlyAllowedFields(['name', 'creatorId', 'isDirect', 'members'])
                    && request.resource.data.creatorId == request.auth.uid
                    && request.auth.uid in request.resource.data.members
                    && request.resource.data.name is string
                    && request.resource.data.isDirect is bool
                    && request.resource.data.members is list;
                    
      // Only members can update the room (e.g., adding new members)
      allow update: if isMember(roomId)
                    && hasOnlyAllowedFields(['name', 'creatorId', 'isDirect', 'members'])
                    && request.resource.data.creatorId == resource.data.creatorId // Immutable
                    && request.resource.data.isDirect == resource.data.isDirect // Immutable
                    && request.resource.data.name is string
                    && request.resource.data.members is list
                    && request.auth.uid in request.resource.data.members; // Must still be a member
                    
      // Room Keys (Encrypted AES keys per member)
      match /keys/{userId} {
        // Only the specific user can read their encrypted key
        allow read: if isOwner(userId);
        
        // Members of the room can write keys for other members (when adding them)
        // Or the creator can write keys when creating the room
        allow create, update: if (isMember(roomId) || get(/databases/$(database)/documents/rooms/$(roomId)).data.creatorId == request.auth.uid)
                              && hasRequiredFields(['encryptedKey', 'iv'])
                              && hasOnlyAllowedFields(['encryptedKey', 'iv'])
                              && request.resource.data.encryptedKey is string
                              && request.resource.data.iv is string;
      }
      
      // Room Messages
      match /messages/{messageId} {
        // Only members can read messages, or the sender can read their own messages (for cleanup)
        allow read: if isMember(roomId) || (isAuthenticated() && resource.data.senderId == request.auth.uid);
        
        // Only members can send messages, and they must be the sender
        allow create: if isMember(roomId)
                      && hasRequiredFields(['senderId', 'ciphertext', 'iv', 'timestamp'])
                      && hasOnlyAllowedFields(['senderId', 'ciphertext', 'iv', 'timestamp'])
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.ciphertext is string
                      && request.resource.data.iv is string
                      && request.resource.data.timestamp is number;
                      
        // Messages are immutable (no updates)
        allow update: if false;
        
        // Messages can be deleted by members (e.g., for ephemeral cleanup) or by the sender
        allow delete: if isMember(roomId) || (isAuthenticated() && resource.data.senderId == request.auth.uid);
      }
    }
  }
}
